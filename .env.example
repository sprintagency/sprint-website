# ---- Resend (contact form email) ----
# Create a key at https://resend.com and verify the sending domain.
RESEND_API_KEY=

# From/To for contact enquiries. FROM's domain must be verified in Resend.
CONTACT_FROM="Sprint Website <web@portal.madebysprint.com>"
CONTACT_TO="hello@madebysprint.com"

# ---- Supabase (contact_submissions storage) ----
# The contact API inserts each submission into the `contact_submissions`
# table. Run supabase/contact_submissions.sql once to create it.
# The Vercel <-> Supabase integration provides these automatically; the
# server route prefers the service-role key (bypasses RLS, server-only).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Fallbacks the route will also read if the above are absent:
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_ANON_KEY=            (requires the RLS insert policy in the SQL)

# ---- Mini SEO CMS (per-page SEO overrides) ----
# The /admin/seo editor and its API (/api/admin/seo) are gated by this shared
# secret, sent as the x-admin-secret header. If unset, the SEO editor is
# disabled (fail closed). Reads the page_seo table (supabase/page_seo.sql).
# Use a long random value.
ADMIN_SEO_SECRET=
