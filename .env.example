# ---- Resend (contact form email) ----
# Create a key at https://resend.com and verify the sending domain.
RESEND_API_KEY=

# From/To for contact enquiries. FROM's domain must be verified in Resend.
CONTACT_FROM="Sprint Website <web@portal.madebysprint.com>"
CONTACT_TO="hello@madebysprint.com"

# ---- Supabase (contact_submissions storage) ----
# The contact API inserts each submission into the `contact_submissions`
# table. Run supabase/contact_submissions.sql once to create it.
# The Vercel <-> Supabase integration provides these automatically; the
# server route prefers the service-role key (bypasses RLS, server-only).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Fallbacks the route will also read if the above are absent:
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_ANON_KEY=            (requires the RLS insert policy in the SQL)

# ---- Mini SEO CMS (per-page SEO overrides) ----
# The /admin/seo editor signs in with this email + password. On success the
# login endpoint issues a short-lived signed session token used for the
# read/write calls. If either is unset, sign-in is disabled (fail closed).
# Reads/writes the page_seo table (supabase/page_seo.sql).
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Secret used to sign SEO admin session tokens (HMAC-SHA256). Any long random
# string; generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# If unset, sign-in fails closed (no token can be issued).
ADMIN_SESSION_SECRET=

# ---- Cloudflare Turnstile ("check you are human" on SEO admin sign-in) ----
# Create a widget at https://dash.cloudflare.com/?to=/:account/turnstile
# The site key is public (served to the browser at runtime); the secret key is
# server-only. If TURNSTILE_SECRET_KEY is unset, the human check is skipped.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---- Upstash Redis (rate limiting on SEO admin sign-in + API) ----
# Create a free Redis database at https://console.upstash.com and copy the
# REST URL + token. If unset, rate limiting is skipped (not enforced).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
